{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zauri",
  "version": "0.5.0",
  "identifier": "com.zauri.editor",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Zauri Editor",
        "width": 1200,
        "height": 800,
        "minWidth": 600,
        "minHeight": 400
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/pentium-solver/zauri/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEYyOEQ4MzQ3Qjk1MjdDNTUKUldSVmZGSzVSNE9OOGwyT3U1bzFWWmo2d3Z3NS9GUWMwMlRiUmFZWjNHSHZOTUpzMFdQQVpZcUoK"
    }
  }
}
